# release.env.example — signing configuration for the release scripts.
#
# Copy this file to release.env (which is gitignored) and fill in your own
# values, OR export these variables in your shell before running the scripts.
# notarize.sh and submit_mas.sh source release.env automatically if present.
#
#   cp release.env.example release.env
#   $EDITOR release.env
#
# Your Apple Developer Team ID (10 chars, e.g. ABCDE12345). Find it at
# https://developer.apple.com/account → Membership details.
TEAM_ID="YOURTEAMID"

# The Apple ID email used for App Store Connect / altool uploads (submit_mas.sh).
APPLE_ID="you@example.com"
